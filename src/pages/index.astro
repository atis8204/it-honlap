<!doctype html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Attila Nagy | IT Üzemeltetés & Hálózatbiztonság</title>

  <style>
    :root {
      --bg: #050816;
      --card: #0b1224;
      --accent: #3b82f6;
      --text: #e5e7eb;
      --muted: #9ca3af;
    }

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 40px;
}
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
    }

    /* NAVBAR */

    header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  padding: 18px 40px;

  display: flex;
  justify-content: center; /* <-- EZ A LÉNYEG */
  align-items: center;

  background: rgba(5, 8, 22, 0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255,255,255,0.05);
  z-index: 100;
}

    .logo {
      font-weight: bold;
      color: white;
      letter-spacing: 1px;
    }


nav {
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 40px;
}
    nav a {
  position: relative;
  text-decoration: none;
  color: var(--muted);
  transition: 0.3s;
  padding: 6px 0;
}

    nav a:hover {
  color: var(--text);
}

nav a.active {
  color: var(--accent);
}

  #net-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  }

nav a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -5px;
  width: 0%;
  height: 2px;
  background: var(--accent);
  transition: 0.3s;
  box-shadow: 0 0 12px var(--accent);
}

nav a:hover::after {
  width: 100%;
}
    /* HERO */
   .hero {
  height: 100vh;
  width: 100%;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

    .hero-content {
     position: relative;
     z-index: 2;
    }

.proof {
  padding: 40px 10%;
  position: relative;
  z-index: 2;
  background: rgba(11, 18, 36, 0.6);
  backdrop-filter: blur(10px);
  border-top: 1px solid rgba(255,255,255,0.05);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.proof-items {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  color: #e5e7eb;
}

.proof-items div {
  padding: 10px 14px;
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.2);
  border-radius: 10px;
  font-size: 0.95rem;
}

    h1 {
      font-size: 3.5rem;
    }

    h1 span {
      color: var(--accent);
    }

    h2 {
      margin-top: 10px;
      color: var(--muted);
      font-weight: 400;
    }

    p {
      margin-top: 20px;
      color: var(--muted);
      line-height: 1.6;
    }

    .buttons {
      margin-top: 30px;
    }

    .btn {
      display: inline-block;
      padding: 12px 20px;
      margin-right: 10px;
      border-radius: 8px;
      text-decoration: none;
      background: var(--accent);
      color: white;
      transition: 0.2s;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn.secondary {
      background: transparent;
      border: 1px solid var(--accent);
    }

    /* SECTIONS */
    section {
      padding: 100px 10%;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 40px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

.dot {
  display: inline-block;
  width: 7px;
  height: 7px;
  margin-right: 6px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 10px #22c55e;
  animation: pulse 1.6s infinite;
  vertical-align: middle;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.4); opacity: 0.4; }
}
    .card {
      background: var(--card);
      padding: 20px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.05);
    }

    .card h3 {
      color: var(--accent);
      margin-bottom: 10px;
    }

    footer {
      padding: 40px;
      text-align: center;
      color: var(--muted);
      border-top: 1px solid rgba(255,255,255,0.05);
    }
  </style>
</head>

<body>
<canvas id="net-bg"></canvas>
  <!-- NAV -->
  <header>
  <nav>
  <a href="#home" class="active">
