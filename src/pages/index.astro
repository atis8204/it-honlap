<!doctype html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Attila Nagy | IT Üzemeltetés & Hálózatbiztonság</title>

  <style>
    :root {
      --bg: #050816;
      --card: #0b1224;
      --accent: #3b82f6;
      --text: #e5e7eb;
      --muted: #9ca3af;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
    }

    /* NAVBAR */
    header {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      padding: 25px 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      background: transparent;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      z-index: 100;
    }

    .logo {
      font-weight: bold;
      color: white;
      letter-spacing: 1px;
    }

    nav {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 35px;
      padding: 15px 40px;
      background: rgba(30, 41, 59, 0.55) !important; 
      backdrop-filter: blur(15px);       
      border-radius: 50px;               
      border: 2px solid rgba(59, 130, 246, 0.7) !important; 
      box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.6); 
      max-width: fit-content; 
    }

    nav a {
      position: relative;
      text-decoration: none;
      color: #9ca3af !important;
      transition: 0.3s;
      padding: 8px 0;
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: 0.9px;
      text-transform: uppercase;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
    }

    nav a:hover {
      color: #ffffff !important;
    }

    nav a.active, 
    nav.nav-menu a.active {
      color: #3b82f6 !important;
    }

    nav a::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -5px;
      width: 0%;
      height: 2px;
      background: var(--accent);
      transition: 0.3s;
      box-shadow: 0 0 12px var(--accent);
    }

    nav a:hover::after {
      width: 100%;
    }

    .dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      margin-right: 12px;
      border-radius: 50%;
      background: #22c55e;
      box-shadow: 0 0 10px #22c55e;
      animation: pulse 1.6s infinite;
      vertical-align: middle;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.4); opacity: 0.4; }
    }

    /* HAMBURGER */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: space-between;
      width: 30px;
      height: 21px;
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 0;
      z-index: 110;
    }

    .hamburger span {
      width: 100%;
      height: 3px;
      background-color: #fff;
      border-radius: 3px;
      transition: all 0.3s ease;
    }

    /* SECTIONS GENERAL */
    section {
      min-height: 100vh; 
      padding-top: 120px; 
      padding-bottom: 40px;
      display: flex;
      flex-direction: column;
      justify-content: center; 
      align-items: center;
      box-sizing: border-box;
      position: relative;
      z-index: 1;
    }

    .section-title {
      font-size: 2.5rem;
      margin-bottom: 40px;
      color: #fff;
      text-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      width: 100%;
      max-width: 1100px;
      padding: 0 20px;
    }

    .card {
      background: var(--card);
      padding: 30px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.05);
      width: 100%;
      max-width: 800px;
    }

    .card h3 {
      color: var(--accent);
      margin-bottom: 10px;
    }

    /* BACKGROUND CANVAS */
    #net-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* HERO STYLES */
    .hero-section {
      padding-top: 80px;
    }

    .hero-container {
      max-width: 800px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 25px;
      text-align: center;
    }

    .tech-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(59, 130, 246, 0.08);
      border: 1px solid rgba(59, 130, 246, 0.25);
      padding: 6px 16px;
      border-radius: 30px;
      color: #60a5fa;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 2px;
    }

    .pulse-glow {
      width: 6px;
      height: 6px;
      background: #22c55e;
      border-radius: 50%;
      box-shadow: 0 0 8px #22c55e;
    }

    .hero-title {
      font-size: 4.2rem;
      font-weight: 800;
      color: #ffffff;
      margin: 0;
      letter-spacing: 0.5px;
      line-height: 1.1;
      text-shadow: 0 0 40px rgba(59, 130, 246, 0.15); 
    }

    .hero-tags {
      display: flex;
      gap: 15px;
      font-size: 1.2rem;
      font-weight: 600;
    }

    .hero-tags .tag { color: #60a5fa; }
    .tag-divider { color: #475569; }

    .hero-description {
      font-size: 1.15rem;
      color: #94a3b8;
      line-height: 1.7;
      max-width: 680px;
    }

    .hero-highlight-block {
      display: block;
      margin-top: 16px;
      color: #ffffff !important;
      font-weight: 700;
      font-size: 1.3rem;
      letter-spacing: 0.5px;
    }

    .hero-buttons {
      display: flex;
      gap: 15px;
      margin-top: 15px;
    }

    .btn-primary {
      background: #2563eb;
      color: #ffffff !important;
      text-decoration: none;
      padding: 14px 28px;
      border-radius: 8px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: all 0.25s ease;
      box-shadow: 0 4px 20px rgba(37, 99, 235, 0.3);
    }

    .btn-primary:hover {
      background: #1d4ed8;
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(37, 99, 235, 0.5);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.02);
      color: #ffffff !important;
      text-decoration: none;
      padding: 14px 28px;
      border-radius: 8px;
      font-weight: 600;
      border: 1px solid rgba(255, 255, 255, 0.12);
      transition: all 0.25s ease;
      backdrop-filter: blur(5px);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(59, 130, 246, 0.5);
      transform: translateY(-2px);
    }

    /* PROOF SECTION */
    .proof {
      min-height: auto;
      padding: 40px 10%;
      background: rgba(11, 18, 36, 0.6);
      backdrop-filter: blur(10px);
      border-top: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .proof-items {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      color: #e5e7eb;
    }

    .proof-items div {
      padding: 10px 14px;
      background: rgba(59, 130, 246, 0.1);
      border: 1px solid rgba(59, 130, 246, 0.2);
      border-radius: 10px;
      font-size: 0.95rem;
    }

    /* CONTACT CARD */
    .contact-links {
      display: flex;
      flex-direction: column;
      gap: 15px;
      align-items: center;
      margin-top: 20px;
    }

    .contact-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: #ffffff !important;
      font-size: 1.1rem;
      transition: all 0.3s ease;
    }

    .contact-item span:last-child {
      color: #60a5fa !important;
    }

    .contact-item:hover span:last-child {
      color: #3b82f6 !important;
      text-decoration: underline;
    }

    /* RESPONSIVE DESIGN */
    @media (max-width: 1024px) {
      header {
        justify-content: flex-end;
        padding: 20px;
      }

      .hamburger {
        display: flex;
      }

      nav.nav-menu {
        position: absolute;
        top: -600px;
        right: 20px;
        left: 20px;
        max-width: none;
        flex-direction: column;
        gap: 25px;
        padding: 35px 20px;
        border-radius: 20px;
        opacity: 0;
        pointer-events: none;
        transition: all 0.4s ease-in-out;
        background: rgba(10, 17, 39, 0.98) !important; 
        backdrop-filter: blur(20px);
        border: 2px solid rgba(59, 130, 246, 0.8) !important;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
      }

      nav.nav-menu.active {
        top: 80px;
        opacity: 1;
        pointer-events: auto;
      }

      nav.nav-menu a {
        width: 100%;
        text-align: center;
        padding: 10px 0;
        font-size: 1.2rem;
        color: #ffffff !important;
      }

      .hamburger.active span:nth-child(1) {
        transform: translateY(9px) rotate(45deg);
      }
      .hamburger.active span:nth-child(2) {
        opacity: 0;
      }
      .hamburger.active span:nth-child(3) {
        transform: translateY(-9px) rotate(-45deg);
      }
    }

    @media (max-width: 768px) {
      .hero-title {
        font-size: 2.8rem;
      }
      
      .hero-tags {
        font-size: 1.1rem;
        flex-direction: column;
        gap: 5px;
      }
      
      .tag-divider {
        display: none;
      }
      
      .hero-buttons {
        flex-direction: column;
        width: 100%;
        max-width: 300px;
        gap: 12px;
      }
      
      .btn-primary, .btn-secondary {
        text-align: center;
        width: 100%;
      }
    }

    footer {
      padding: 40px;
      text-align: center;
      color: var(--muted);
      border-top: 1px solid rgba(255,255,255,0.05);
      position: relative;
      z-index: 1;
    }
  </style>
</head>

<body>
  <canvas id="net-bg"></canvas>

  <header>
    <button class="hamburger" aria-label="Menü megnyitása">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="nav-menu">  
      <a href="#home" class="active">Főoldal</a>
      <a href="#services">Szolgáltatások</a>
      <a href="#solutions">Megoldások</a>
      <a href="#projects">Projektek</a>
      <a href="#contact">Kapcsolat</a>
    </nav>
  </header>

  <section id="home" class="hero-section">
    <div class="hero-container">
      <div class="tech-badge">
