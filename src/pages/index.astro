<!doctype html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nagy Attila | IT Üzemeltetés & Hálózatbiztonság</title>
  <style>
    :root {
      --bg: #050816;
      --card: #0b1224;
      --accent: #3b82f6;
      --accent2: #22c55e;
      --text: #e5e7eb;
      --muted: #9ca3af;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; font-family: system-ui, sans-serif; }

    body { background: var(--bg); color: var(--text); overflow-x: hidden; }

    /* ── CANVAS ── */
    #net-bg { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

    /* ── NAVBAR ── */
    header {
      position: fixed; top: 0; left: 0; width: 100%;
      padding: 22px 20px;
      display: flex; justify-content: center; align-items: center;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      z-index: 100;
    }

    nav {
      display: flex; justify-content: center; align-items: center;
      gap: 35px; padding: 14px 40px;
      background: rgba(30,41,59,0.55);
      backdrop-filter: blur(15px);
      border-radius: 50px;
      border: 2px solid rgba(59,130,246,0.7);
      box-shadow: 0 10px 40px rgba(0,0,0,0.6);
      max-width: fit-content;
    }

    nav a {
      position: relative; text-decoration: none;
      color: var(--muted); transition: 0.3s;
      padding: 8px 0; font-size: 1rem; font-weight: 600;
      letter-spacing: 0.9px; text-transform: uppercase; white-space: nowrap;
    }
    nav a:hover { color: var(--text); }
    nav a.active { color: var(--accent); }
    nav a::after {
      content: ""; position: absolute; left: 0; bottom: -4px;
      width: 0%; height: 2px; background: var(--accent);
      transition: 0.3s; box-shadow: 0 0 12px var(--accent);
    }
    nav a:hover::after { width: 100%; }

    .dot {
      display: inline-block; width: 10px; height: 10px;
      margin-right: 10px; border-radius: 50%;
      background: #22c55e; box-shadow: 0 0 10px #22c55e;
      animation: dotpulse 1.6s infinite; vertical-align: middle;
    }
    @keyframes dotpulse {
      0%,100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.5); opacity: 0.4; }
    }

    .hamburger {
      display: none; flex-direction: column; justify-content: space-between;
      width: 30px; height: 21px; background: transparent;
      border: none; cursor: pointer; padding: 0; z-index: 110;
    }
    .hamburger span { width: 100%; height: 3px; background: #fff; border-radius: 3px; transition: all 0.3s; }

    @media (max-width: 1024px) {
      header { justify-content: flex-end; padding: 20px; }
      .hamburger { display: flex; }
      nav.nav-menu {
        position: absolute; top: -500px; right: 20px; left: 20px;
        max-width: none; flex-direction: column; gap: 25px; padding: 35px 20px;
        border-radius: 20px; opacity: 0; pointer-events: none;
        transition: all 0.4s ease-in-out;
        background: rgba(10,17,39,0.98) !important;
        border: 2px solid rgba(59,130,246,0.8) !important;
      }
      nav.nav-menu.active { top: 80px; opacity: 1; pointer-events: auto; }
      nav.nav-menu a { width: 100%; text-align: center; padding: 10px 0; font-size: 1.2rem; color: #fff !important; }
      .hamburger.active span:nth-child(1) { transform: translateY(9px) rotate(45deg); }
      .hamburger.active span:nth-child(2) { opacity: 0; }
      .hamburger.active span:nth-child(3) { transform: translateY(-9px) rotate(-45deg); }
    }

    /* ── SECTION BASE ── */
    section {
      position: relative; z-index: 1;
      padding: 120px 40px 80px;
      display: flex; flex-direction: column;
      align-items: center;
    }

    .section-title {
      font-size: 2rem; font-weight: 700; margin-bottom: 50px;
      text-align: center; color: #fff;
    }
    .section-title span { color: var(--accent); }

    /* ── HERO ── */
    #home {
      min-height: 100vh; justify-content: center;
      padding-top: 80px; padding-bottom: 40px;
      text-align: center;
    }

    .hero-container {
      max-width: 820px; display: flex; flex-direction: column;
      align-items: center; gap: 28px;
    }

    .tech-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(59,130,246,0.08);
      border: 1px solid rgba(59,130,246,0.3);
      padding: 6px 18px; border-radius: 30px;
      color: #60a5fa; font-size: 0.78rem; font-weight: 700; letter-spacing: 2.5px;
      animation: fadeDown 0.6s ease both;
    }
    .pulse-glow {
      width: 7px; height: 7px; background: #22c55e;
      border-radius: 50%; box-shadow: 0 0 8px #22c55e;
      animation: dotpulse 1.6s infinite;
    }

    .hero-title {
      font-size: 4.5rem; font-weight: 800; color: #fff;
      letter-spacing: 0.5px; line-height: 1.1;
      text-shadow: 0 0 60px rgba(59,130,246,0.2);
      animation: fadeUp 0.7s 0.1s ease both;
    }

    /* typewriter subtitle */
    .hero-typed-wrap {
      font-size: 1.3rem; font-weight: 600;
      color: #60a5fa; min-height: 2rem;
      animation: fadeUp 0.7s 0.2s ease both;
    }
    .cursor { border-right: 2px solid #60a5fa; animation: blink 0.7s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    .hero-description {
      font-size: 1.1rem; color: #94a3b8; line-height: 1.8;
      max-width: 680px; text-align: center;
      animation: fadeUp 0.7s 0.3s ease both;
    }
    .hero-highlight-block {
      display: block; margin-top: 14px;
      color: #fff; font-weight: 700; font-size: 1.25rem;
    }

    .hero-buttons {
      display: flex; gap: 15px; flex-wrap: wrap; justify-content: center;
      animation: fadeUp 0.7s 0.4s ease both;
    }
    .btn-primary {
      background: #2563eb; color: #fff !important; text-decoration: none;
      padding: 14px 30px; border-radius: 8px; font-weight: 600;
      display: flex; align-items: center; gap: 8px;
      transition: all 0.25s; box-shadow: 0 4px 20px rgba(37,99,235,0.3);
    }
    .btn-primary:hover { background: #1d4ed8; transform: translateY(-2px); box-shadow: 0 6px 28px rgba(37,99,235,0.5); }
    .btn-secondary {
      background: rgba(255,255,255,0.03); color: #fff !important; text-decoration: none;
      padding: 14px 30px; border-radius: 8px; font-weight: 600;
      border: 1px solid rgba(255,255,255,0.14); transition: all 0.25s;
    }
    .btn-secondary:hover { background: rgba(255,255,255,0.07); border-color: rgba(59,130,246,0.5); transform: translateY(-2px); }

    /* ── STATS BAR ── */
    .stats-bar {
      width: 100%; display: flex; justify-content: center;
      gap: 0; flex-wrap: wrap;
      background: rgba(11,18,36,0.7);
      backdrop-filter: blur(10px);
      border-top: 1px solid rgba(255,255,255,0.05);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      position: relative; z-index: 2;
    }
    .stat-item {
      flex: 1; min-width: 160px; max-width: 240px;
      padding: 32px 20px; text-align: center;
      border-right: 1px solid rgba(255,255,255,0.05);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-size: 2.6rem; font-weight: 800; color: #fff;
      line-height: 1; display: block;
    }
    .stat-num .accent { color: var(--accent); }
    .stat-label { font-size: 0.85rem; color: var(--muted); margin-top: 6px; letter-spacing: 0.5px; }

    /* ── SKILLS ── */
    #skills { background: transparent; }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px; width: 100%; max-width: 1100px;
    }

    .skill-card {
      background: var(--card);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; padding: 24px 22px;
      transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
      opacity: 0; transform: translateY(30px);
    }
    .skill-card.visible {
      animation: fadeUp 0.5s ease forwards;
    }
    .skill-card:hover {
      transform: translateY(-4px);
      border-color: rgba(59,130,246,0.35);
      box-shadow: 0 8px 32px rgba(59,130,246,0.1);
    }
    .skill-card-header {
      display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
    }
    .skill-icon {
      width: 42px; height: 42px; border-radius: 10px;
      background: rgba(59,130,246,0.12);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }
    .skill-card h3 { color: #60a5fa; font-size: 1rem; font-weight: 700; }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 4px; }
    .skill-tag {
      background: rgba(59,130,246,0.1);
      border: 1px solid rgba(59,130,246,0.2);
      color: #93c5fd; font-size: 0.78rem; font-weight: 600;
      padding: 3px 10px; border-radius: 20px; letter-spacing: 0.3px;
    }

    /* ── EXPERIENCE ── */
    #experience { background: rgba(11,18,36,0.4); }

    .timeline {
      width: 100%; max-width: 820px;
      position: relative; padding-left: 30px;
    }
    .timeline::before {
      content: ""; position: absolute; left: 8px; top: 0; bottom: 0;
      width: 2px; background: linear-gradient(to bottom, rgba(59,130,246,0.6), rgba(59,130,246,0.05));
    }
    .timeline-item {
      position: relative; margin-bottom: 48px;
      opacity: 0; transform: translateX(-20px);
    }
    .timeline-item.visible { animation: fadeRight 0.5s ease forwards; }
    .timeline-dot {
      position: absolute; left: -26px; top: 6px;
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 12px rgba(59,130,246,0.6);
      border: 2px solid var(--bg);
    }
    .timeline-date {
      font-size: 0.8rem; font-weight: 700; letter-spacing: 1.5px;
      color: #60a5fa; text-transform: uppercase; margin-bottom: 6px;
    }
    .timeline-title { font-size: 1.15rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
    .timeline-company { font-size: 0.95rem; color: var(--muted); margin-bottom: 12px; }
    .timeline-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .timeline-list li {
      font-size: 0.92rem; color: #94a3b8; padding-left: 16px; position: relative; line-height: 1.6;
    }
    .timeline-list li::before {
      content: "▸"; position: absolute; left: 0; color: var(--accent); font-size: 0.75rem; top: 2px;
    }

    /* ── EDUCATION ── */
    #education { background: transparent; }
    .edu-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px; width: 100%; max-width: 900px;
    }
    .edu-card {
      background: var(--card); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; padding: 24px;
      opacity: 0; transform: translateY(20px);
      transition: transform 0.3s, border-color 0.3s;
    }
    .edu-card.visible { animation: fadeUp 0.5s ease forwards; }
    .edu-card:hover { transform: translateY(-3px); border-color: rgba(59,130,246,0.3); }
    .edu-year {
      display: inline-block; font-size: 0.75rem; font-weight: 700;
      letter-spacing: 1px; color: #60a5fa;
      background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2);
      padding: 3px 10px; border-radius: 20px; margin-bottom: 12px;
    }
    .edu-card h3 { color: #fff; font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
    .edu-card p { color: var(--muted); font-size: 0.88rem; line-height: 1.5; }

    /* ── CERTS ── */
    .cert-row {
      display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;
      width: 100%; max-width: 900px; margin-top: -10px;
    }
    .cert-badge {
      display: flex; align-items: center; gap: 8px;
      background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.25);
      color: #86efac; font-size: 0.85rem; font-weight: 600;
      padding: 8px 16px; border-radius: 30px;
      opacity: 0; transform: scale(0.9);
    }
    .cert-badge.visible { animation: popIn 0.4s ease forwards; }
    .cert-badge::before { content: "✔"; color: #22c55e; }

    /* ── SERVICES ── */
    #services { background: rgba(11,18,36,0.4); }
    .services-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px; width: 100%; max-width: 1100px;
    }
    .service-card {
      background: var(--card); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; padding: 28px 24px;
      transition: all 0.3s; position: relative; overflow: hidden;
      opacity: 0; transform: translateY(20px);
    }
    .service-card.visible { animation: fadeUp 0.5s ease forwards; }
    .service-card::before {
      content: ""; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, rgba(59,130,246,0.6), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .service-card:hover { transform: translateY(-5px); border-color: rgba(59,130,246,0.3); box-shadow: 0 12px 40px rgba(59,130,246,0.1); }
    .service-card:hover::before { opacity: 1; }
    .service-icon { font-size: 2rem; margin-bottom: 14px; }
    .service-card h3 { color: #60a5fa; font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; }
    .service-card p { color: #94a3b8; font-size: 0.9rem; line-height: 1.7; }

    /* ── CONTACT ── */
    #contact { background: transparent; }
    .contact-card {
      background: var(--card); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px; padding: 40px; max-width: 560px; width: 100%; text-align: center;
    }
    .contact-intro { color: #94a3b8; margin-bottom: 28px; line-height: 1.7; margin-top: 0; }
    .contact-links { display: flex; flex-direction: column; gap: 14px; align-items: center; }
    .contact-item {
      display: inline-flex; align-items: center; gap: 10px;
      text-decoration: none; color: #fff;
      font-size: 1rem; transition: all 0.3s;
      padding: 10px 20px; border-radius: 8px;
      background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.15);
      width: 100%; justify-content: center;
    }
    .contact-item:hover { background: rgba(59,130,246,0.15); transform: translateY(-2px); }
    .contact-item span.val { color: #60a5fa; }

    /* ── FOOTER ── */
    footer {
      padding: 32px 40px; text-align: center; color: var(--muted);
      border-top: 1px solid rgba(255,255,255,0.05);
      font-size: 0.88rem; position: relative; z-index: 1;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
    @keyframes fadeDown { from { opacity:0; transform:translateY(-20px); } to { opacity:1; transform:translateY(0); } }
    @keyframes fadeRight { from { opacity:0; transform:translateX(-20px); } to { opacity:1; transform:translateX(0); } }
    @keyframes popIn { from { opacity:0; transform:scale(0.85); } to { opacity:1; transform:scale(1); } }

    /* ── MOBILE ── */
    @media (max-width: 768px) {
      .hero-title { font-size: 2.8rem; }
      .hero-typed-wrap { font-size: 1.1rem; }
      .hero-buttons { flex-direction: column; width: 100%; max-width: 300px; }
      .btn-primary, .btn-secondary { text-align: center; width: 100%; justify-content: center; }
      section { padding: 100px 20px 60px; }
      .stat-item { min-width: 130px; padding: 24px 12px; }
      .stat-num { font-size: 2rem; }
      .timeline { padding-left: 20px; }
    }
  </style>
</head>
<body>
<canvas id="net-bg"></canvas>

<!-- NAV -->
<header>
  <button class="hamburger" aria-label="Menü megnyitása">
    <span></span><span></span><span></span>
  </button>
  <nav class="nav-menu">
    <a href="#home" class="active"><span class="dot"></span>Főoldal</a>
    <a href="#skills">Készségek</a>
    <a href="#experience">Tapasztalat</a>
    <a href="#services">Szolgáltatások</a>
    <a href="#contact">Kapcsolat</a>
  </nav>
</header>

<!-- HERO -->
<section id="home">
  <div class="hero-container">
    <div class="tech-badge">
      <span class="pulse-glow"></span> NETWORKS & SECURITY
    </div>
    <h1 class="hero-title">Nagy Attila</h1>
    <div class="hero-typed-wrap">
      <span id="typed"></span><span class="cursor">&nbsp;</span>
    </div>
    <p class="hero-description">
      Több mint <strong>20 éves</strong> tapasztalattal kis- és középvállalati IT-infrastruktúrák tervezésében, üzemeltetésében és biztonságának növelésében. Hálózati eszközök konfigurálása, Windows &amp; Linux szerverek menedzsmentje, Microsoft 365 környezetek kezelése.
      <span class="hero-highlight-block">Stabil rendszerek, kiszámítható működés.</span>
    </p>
    <div class="hero-buttons">
      <a href="#contact" class="btn-primary"><span>Kapcsolat felvétele</span><span>→</span></a>
      <a href="#services" class="btn-secondary"><span>Szolgáltatások</span></a>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stat-item">
    <span class="stat-num"><span class="counter accent" data-target="20">0</span><span class="accent">+</span></span>
    <div class="stat-label">Év tapasztalat</div>
  </div>
  <div class="stat-item">
    <span class="stat-num"><span class="counter accent" data-target="2006">0</span></span>
    <div class="stat-label">Munkaviszony kezdete</div>
  </div>
  <div class="stat-item">
    <span class="stat-num"><span class="accent">ISO</span></span>
    <div class="stat-label">27001 tanúsítvány megszerzése</div>
  </div>
  <div class="stat-item">
    <span class="stat-num"><span class="accent">NIS2</span></span>
    <div class="stat-label">Megfelelőség kialakítása</div>
  </div>
</div>

<!-- SKILLS -->
<section id="skills">
  <h2 class="section-title">Szakterületek &amp; <span>Készségek</span></h2>
  <div class="skills-grid">

    <div class="skill-card">
      <div class="skill-card-header">
        <div class="skill-icon">🖧</div>
        <h3>Hálózat & Infrastruktúra</h3>
      </div>
      <div class="skill-tags">
        <span class="skill-tag">Mikrotik</span>
        <span class="skill-tag">VPN</span>
        <span class="skill-tag">VLAN</span>
        <span class="skill-tag">L2TP/IPSEC</span>
        <span class="skill-tag">Multi-site</span>
        <span class="skill-tag">Cisco WLC</span>
        <span class="skill-tag">Zyxel WLC</span>
        <span class="skill-tag">WLAN / SSID</span>
      </div>
    </div>

    <div class="skill-card">
      <div class="skill-card-header">
        <div class="skill-icon">🖥️</div>
        <h3>Windows & Linux Szerverek</h3>
      </div>
      <div class="skill-tags">
        <span class="skill-tag">Active Directory</span>
        <span class="skill-tag">GPO</span>
        <span class="skill-tag">DHCP / DNS</span>
        <span class="skill-tag">Apache</span>
        <span class="skill-tag">MySQL</span>
        <span class="skill-tag">Microsoft 365</span>
      </div>
    </div>

    <div class="skill-card">
      <div class="skill-card-header">
        <div class="skill-icon">⚙️</div>
        <h3>Virtualizáció</h3>
      </div>
      <div class="skill-tags">
        <span class="skill-tag">Hyper-V</span>
        <span class="skill-tag">VMware ESXi</span>
        <span class="skill-tag">Snapshot kezelés</span>
        <span class="skill-tag">Erőforrás optimalizálás</span>
      </div>
    </div>

    <div class="skill-card">
      <div class="skill-card-header">
        <div class="skill-icon">🔒</div>
        <h3>IT-biztonság & Compliance</h3>
      </div>
      <div class="skill-tags">
        <span class="skill-tag">ISO 27001</span>
        <span class="skill-tag">NIS2</span>
        <span class="skill-tag">Endpoint security</span>
        <span class="skill-tag">Backup tervezés</span>
        <span class="skill-tag">Incidenskezelés</span>
        <span class="skill-tag">Audit felkészítés</span>
      </div>
    </div>

    <div class="skill-card">
      <div class="skill-card-header">
        <div class="skill-icon">📹</div>
        <h3>Kamera & Beléptetés</h3>
      </div>
      <div class="skill-tags">
        <span class="skill-tag">Hikvision NVR/DVR</span>
        <span class="skill-tag">IP kamerák</span>
        <span class="skill-tag">Hálózati integráció</span>
        <span class="skill-tag">Beléptető rendszerek</span>
      </div>
    </div>

    <div class="skill-card">
      <div class="skill-card-header">
        <div class="skill-icon">🗄️</div>
        <h3>NAS & Backup</h3>
      </div>
      <div class="skill-tags">
        <span class="skill-tag">Synology</span>
        <span class="skill-tag">Mentési stratégiák</span>
        <span class="skill-tag">Adatbázis backup</span>
        <span class="skill-tag">JIRA ticketing</span>
      </div>
    </div>

  </div>
</section>

<!-- EXPERIENCE -->
<section id="experience">
  <h2 class="section-title">Szakmai <span>Tapasztalat</span></h2>
