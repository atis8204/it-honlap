/* A leírás végén lévő kiemelt mondat tiszta fehér és hangsúlyos lesz */
.hero-highlight {
  color: #ffffff !important;
  font-weight: 700;
  border-bottom: 1px dashed rgba(59, 130, 246, 0.4); /* Egy nagyon finom, szaggatott kék aláhúzás a nyomaték kedvéért */
