}

/* Felső jelvény pulzálással */
.tech-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(59, 130, 246, 0.08);
  border: 1px solid rgba(59, 130, 246, 0.25);
  padding: 6px 16px;
  border-radius: 30px;
  color: #60a5fa;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 2px;
}

.pulse-glow {
  width: 6px;
  height: 6px;
  background: #22c55e; /* Én zöldet raknék ide, mint a fenti menüdben, utalva arra, hogy a rendszer ONLINE */
  border-radius: 50%;
  box-shadow: 0 0 8px #22c55e;
}

@keyframes pulse {
  0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7); }
  70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(59, 130, 246, 0); }
  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
}

/* Főcím (Név) - Fehér, vastag, pici betűközzel és kék mélységgel */
