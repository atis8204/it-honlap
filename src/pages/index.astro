      </div>

      <h1 class="hero-title">Nagy Attila</h1>
      
      <div class="hero-tags">
        <span class="tag">Hálózatüzemeltetés</span>
        <span class="tag-divider">•</span>
        <span class="tag">IT-biztonság</span>
        <span class="tag-divider">•</span>
        <span class="tag">Linux rendszerek</span>
