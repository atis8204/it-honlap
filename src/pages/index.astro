  margin: 0 auto;
  padding: 0 40px;
}
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
    }

    /* NAVBAR */

    header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  padding: 25px 20px;
  display: flex;
  justify-content: center; /* <-- EZ A LÉNYEG */
  align-items: center;
  background: transparent;
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255,255,255,0.05);
  z-index: 100;
}

    .logo {
      font-weight: bold;
      color: white;
      letter-spacing: 1px;
    }


/* EZ LESZ AZ OVÁLIS KAPSZULA MÖGÖTTÜK */
nav {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 35px;
  padding: 15px 40px;
  
  /* --- AZ ÉN JAVASLATOM: JÓL LÁTHATÓ TECH-KÉK ÜVEG HÁTTÉR --- */
  background: rgba(30, 41, 59, 0.55) !important; 
  backdrop-filter: blur(15px);       
  border-radius: 50px;               
  
  /* Biztosra megyünk: kap egy határozott, elegáns kék keretet */
  border: 2px solid rgba(59, 130, 246, 0.7) !important; 
  box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.6); 
  max-width: fit-content; 
}

/* MENÜPONTOK STÍLUSA */
nav a {
  position: relative;
  text-decoration: none;
  color: var(--muted);
  transition: 0.3s;
  padding: 8px 0;
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.9px;
  text-transform: uppercase;
  white-space: nowrap;
}

/* A linkeket összefogó konténer - ez rakja őket egymás alá */
.contact-links {
  display: flex;
  flex-direction: column; /* Szigorúan egymás alá rakja az elemeket */
  gap: 15px;              /* Távolság a két link között */
  align-items: center;    /* Vízszintesen középre igazítja őket a kártyán belül */
  margin-top: 20px;
}

.contact-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  text-decoration: none; /* <-- Ez leveszi a gyári aláhúzást */
  color: #ffffff !important; /* <-- A feliratok (Email:, LinkedIn:) maradjanak fehérek */
  font-size: 1.1rem;
  transition: all 0.3s ease;
}

/* Kifejezetten a kattintható címek (info@netopslab.hu és a linkedin URL) színe */
.contact-item span:last-child {
  color: #60a5fa !important; /* Jól olvasható, világos hálózati kék */
  text-decoration: none;
}

/* Hover effekt: ha fölé viszed az egeret */
.contact-item:hover span:last-child {
  color: #3b82f6 !important;  /* Élénkebb kékre vált */
  text-decoration: underline; /* Csak ekkor húzza alá */
}

/* --- A HAMBURGER GOMB STÍLUSA (Asztali gépen teljesen rejtve van) --- */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: space-between;
  width: 30px;
  height: 21px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0;
  z-index: 110; /* Hogy a menü felett maradjon */
}

/* A hamburger gomb 3 fehér vonala */
.hamburger span {
  width: 100%;
  height: 3px;
  background-color: #fff;
  border-radius: 3px;
  transition: all 0.3s ease;
}

/* --- REJSZPONZÍV VARÁZSLAT MOBILRA ÉS TABLETRE (1024px alatt) --- */
@media (max-width: 1024px) {
  header {
    justify-content: flex-end; /* Mobilon a gombot kitolja a jobb szélre */
    padding: 20px;
  }

  .hamburger {
    display: flex; /* Mobilon megjelenik a 3 vonal */
  }

 /* A kapszula mobilos lenyíló kártyája */
  nav.nav-menu {
    position: absolute;
    top: -500px; /* Alapból elrejtve fent */
    right: 20px;
    left: 20px;
    max-width: none;
    flex-direction: column; /* Egymás alá rakja a pontokat */
    gap: 25px;
    padding: 35px 20px;
    border-radius: 20px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s ease-in-out;
    
    /* --- EZ MEGVÉDI A SZÖVEGET: TÖMÖR, SÖTÉT KÉKÜVEG HÁTTÉR --- */
    background: rgba(10, 17, 39, 0.98) !important; 
    backdrop-filter: blur(20px);
    border: 2px solid rgba(59, 130, 246, 0.8) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
  }

/* Amikor megnyitod a hamburgerrel */
  nav.nav-menu.active {
    top: 80px; /* Beúszik a képernyőre */
    opacity: 1;
    pointer-events: auto;
  }

  /* Mobilos menüpontok finomhangolása (középre zárás, jobb olvashatóság) */
  nav.nav-menu a {
    width: 100%;
    text-align: center;
    padding: 10px 0;
    font-size: 1.2rem;
    color: #ffffff !important; /* tiszta fehér betűk a tökéletes kontraszthoz */
  }

  /* ANIMÁCIÓ: A hamburger gomb X-é változik, amikor aktív */
  .hamburger.active span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0; /* A középső vonal eltűnik */
  }
  .hamburger.active span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }
}
    nav a:hover {
  color: var(--text);
}

nav a.active {
  color: var(--accent);
}

  #net-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  }

nav a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -5px;
  width: 0%;
  height: 2px;
  background: var(--accent);
  transition: 0.3s;
  box-shadow: 0 0 12px var(--accent);
}

nav a:hover::after {
  width: 100%;
}
