      <p>
        Infrastruktúrák tervezése, üzemeltetése és biztonságos működtetése.
        Stabil rendszerek, megbízható működés, folyamatos rendelkezésre állás.
      </p>

      <div class="buttons">
        <a class="btn" href="#contact">Kapcsolat</a>
        <a class="btn secondary" href="#services">Szolgáltatások</a>
      </div>
    </div>
  </div>
  </section>

<!-- 🚀 PROOF SOR (EZ JÖN UTÁNA) -->
<section class="proof">
  <div class="proof-items">
    <div>✔ Linux szerver üzemeltetés</div>
    <div>✔ Hálózati infrastruktúra</div>
    <div>✔ Synology / backup rendszerek</div>
    <div>✔ IT security alapok</div>
  </div>
</section>

  <!-- SERVICES -->
  <section id="services">
    <h2 class="section-title">Szolgáltatások</h2>

    <div class="grid">
      <div class="card">
        <h3>Hálózatüzemeltetés</h3>
        <p>Routerek, switchek, infrastruktúra tervezés és karbantartás.</p>
      </div>

      <div class="card">
