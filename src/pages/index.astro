---
// src/pages/index.astro
---

<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nagy Attila | Informatikai Mérnök & Rendszerüzemeltető</title>
    <!-- Tailwind CSS (ha a sablonod globálisan kezeli, ez a sor elhagyható, de biztosítéknak jó) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-gray-900 text-gray-100 font-sans">

    <!-- Navigációs sáv (Menü) -->
    <nav class="sticky top-0 z-50 bg-gray-900/90 backdrop-blur-md border-b border-gray-800 py-4 px-6">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <a href="#" class="text-xl font-bold tracking-tight text-blue-500">AN<span class="text-white">_IT</span></a>
        <div class="space-x-6 text-sm font-medium">
          <a href="#fooldal" class="hover:text-blue-400 transition">Főoldal</a>
          <a href="#szolgaltatasok" class="hover:text-blue-400 transition">Szolgáltatások</a>
          <a href="#rolam" class="hover:text-blue-400 transition">Rólam</a>
          <a href="#kapcsolat" class="hover:text-blue-400 transition">Kapcsolat</a>
        </div>
      </div>
    </nav>

    <!-- FŐOLDAL (Hero szekció) -->
    <header id="fooldal" class="min-h-[85vh] flex items-center justify-center px-6 border-b border-gray-800">
      <div class="max-w-3xl text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-4">
          Biztonságos és Skálázható <br/>
          <span class="bg-clip-text text-transparent bg-gradient-to-r bg-blue-500 to-teal-400">IT Infrastruktúra</span>
        </h1>
        <p class="text-gray-400 text-lg md:text-xl mb-8 max-w-2xl mx-auto">
          Mérnökinformatikusi szemlélet, vállalati hálózatbiztonság, rendszerüzemeltetés és NIS2 megfelelőség – az üzletmenet folytonosságáért.
        </p>
        <div class="flex justify-center gap-4">
          <a href="#szolgaltatasok" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-6 rounded-lg transition shadow-lg shadow-blue-600/20">
            Szolgáltatások
          </a>
          <a href="#kapcsolat" class="border border-gray-700 hover:border-gray-500 text-gray-300 font-medium py-3 px-6 rounded-lg transition">
            Kapcsolatfelvétel
          </a>
        </div>
      </div>
    </header>

    <!-- SZOLGÁLTATÁSOK SZEKCIÓ -->
    <section id="szolgaltatasok" class="py-20 px-6 max-w-6xl mx-auto border-b border-gray-800">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold mb-4">Miben tudok segíteni?</h2>
        <p class="text-gray-400">Szakértői támogatás az IT infrastruktúra minden kritikus pontján.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- 1. Hálózatkezelés -->
        <div class="bg-gray-800/50 border border-gray-800 p-8 rounded-xl hover:border-blue-500/50 transition">
          <div class="w-12 h-12 bg-blue-500/10 text-blue-400 flex items-center justify-center rounded-lg mb-6 font-bold text-lg">01</div>
          <h3 class="text-xl font-bold mb-3">Vállalati Hálózatok (MikroTik)</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            RouterOS rendszerek tervezése és finomhangolása. VLAN szegmentáció, OSPF routing, redundáns útvonalak és szigorú tűzfalszabályok kialakítása.
          </p>
        </div>

        <!-- 2. M365 & Felhő -->
        <div class="bg-gray-800/50 border border-gray-800 p-8 rounded-xl hover:border-blue-500/50 transition">
          <div class="w-12 h-12 bg-teal-500/10 text-teal-400 flex items-center justify-center rounded-lg mb-6 font-bold text-lg">02</div>
          <h3 class="text-xl font-bold mb-3">Microsoft 365 & Entra ID</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Tenant adminisztráció, Conditional Access (feltételes hozzáférés) szabályok, identitásvédelem, valamint levelezésbiztonság (DMARC, karantén szabályok).
          </p>
        </div>

        <!-- 3. Kiberbiztonság / NIS2 -->
        <div class="bg-gray-800/50 border border-gray-800 p-8 rounded-xl hover:border-blue-500/50 transition">
          <div class="w-12 h-12 bg-purple-500/10 text-purple-400 flex items-center justify-center rounded-lg mb-6 font-bold text-lg">03</div>
          <h3 class="text-xl font-bold mb-3">NIS2 & ISO 27001 Audit</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Információbiztonsági rendszerek (ISMS) előkészítése, eszköz- és kockázatértékelési folyamatok támogatása, megfelelőségi felkészítés vállalkozásoknak.
          </p>
        </div>
      </div>
    </section>

    <!-- RÓLAM SZEKCIÓ -->
    <section id="rolam" class="py-20 px-6 max-w-4xl mx-auto border-b border-gray-800">
      <div class="grid md:grid-cols-3 gap-10 items-center">
        <div class="md:col-span-2">
          <h2 class="text-3xl font-bold mb-6">Szakmai háttér</h2>
          <p class="text-gray-300 mb-4 leading-relaxed">
            Mérnökinformatikusként és IT rendszermérnökként hiszek abban, hogy a stabil informatikai háttér nem luxus, hanem az üzleti biztonság alapja. Több éves vállalati tapasztalattal rendelkezem komplex hálózati architektúrák üzemeltetésében és kiberbiztonsági auditokra való felkészítésében.
          </p>
          <p class="text-gray-400 text-sm">
            Fő fókusz: Hálózatbiztonság • Serverless architektúrák • Compliance irányelvek
          </p>
        </div>
        <div class="bg-gradient-to-br from-blue-600 to-teal-500 p-1 rounded-2xl shadow-xl">
          <div class="bg-gray-900 p-6 rounded-2xl text-center">
            <span class="text-5xl font-extrabold text-white">40+</span>
            <p class="text-gray-400 text-xs uppercase tracking-wider mt-2">Életkor & Tapasztalat</p>
          </div>
        </div>
      </div>
    </section>

    <!-- KAPCSOLAT SZEKCIÓ -->
    <section id="kapcsolat" class="py-20 px-6 max-w-xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold mb-4">Kapcsolatfelvétel</h2>
        <p class="text-gray-400">Kérdésed van? Kérj konzultációt az alábbi űrlapon keresztül.</p>
      </div>

      <!-- Ide jön majd a Formspree action, ha meglesz az ID -->
      <form action="#" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Név</label>
          <input type="text" name="name" required class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition"/>
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">E-mail cím</label>
          <input type="email" name="email" required class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition"/>
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wider text-gray-400 font-semibold mb-2">Üzenet</label>
          <textarea name="message" rows="4" required class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition"></textarea>
        </div>
        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition shadow-lg shadow-blue-600/10">
          Üzenet elküldése
        </button>
      </form>
    </section>

    <!-- LÁBLÉC (Hivatalos adatokkal) -->
    <footer class="bg-gray-950 py-8 px-6 text-center text-xs text-gray-500 border-t border-gray-900">
      <div class="max-w-6xl mx-auto space-y-2">
        <p>&copy; 2026 Nagy Attila EV. Minden jog fenntartva.</p>
        <p>Székhely: [Székhelyed] | Adószám: [Adószámod] | Nyilvántartási szám: [Nyilvántartási számod]</p>
      </div>
    </footer>

  </body>
</html>