  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    :root { --bg: #050816; --card: #0b1224; --accent: #3b82f6; --text: #e5e7eb; --muted: #9ca3af; }
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: system-ui, sans-serif; }
    body { background: var(--bg); color: var(--text); }
    header { position: fixed; top: 0; left: 0; width: 100%; padding: 22px 20px; display: flex; justify-content: center; backdrop-filter: blur(10px); border-bottom: 1px solid rgba(255,255,255,0.05); z-index: 100; }
    nav { display: flex; gap: 35px; padding: 14px 40px; background: rgba(30,41,59,0.55); backdrop-filter: blur(15px); border-radius: 50px; border: 2px solid rgba(59,130,246,0.7); }
    nav a { text-decoration: none; color: var(--muted); font-size: 1rem; font-weight: 600; letter-spacing: 0.9px; text-transform: uppercase; transition: 0.3s; }
    nav a:hover { color: var(--text); }
    .blog-wrap { max-width: 900px; margin: 0 auto; padding: 140px 24px 80px; }
    .blog-header { text-align: center; margin-bottom: 60px; }
    .blog-header h1 { font-size: 2.4rem; font-weight: 700; color: #fff; margin-bottom: 12px; }
    .blog-header h1 span { color: var(--accent); }
    .blog-header p { color: var(--muted); font-size: 1.05rem; }
    .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 24px; }
    .post-card { background: var(--card); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 28px; transition: all 0.3s; text-decoration: none; display: block; }
    .post-card:hover { transform: translateY(-4px); border-color: rgba(59,130,246,0.35); box-shadow: 0 12px 40px rgba(59,130,246,0.1); }
    .post-tag { display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; margin-bottom: 14px; background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3); color: #93c5fd; }
    .post-card h2 { color: #fff; font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; line-height: 1.4; }
    .post-card p { color: #94a3b8; font-size: 0.92rem; line-height: 1.7; margin-bottom: 16px; }
    .post-meta { color: var(--muted); font-size: 0.82rem; }
    footer { padding: 32px; text-align: center; color: var(--muted); border-top: 1px solid rgba(255,255,255,0.05); font-size: 0.88rem; }
    @media (max-width: 768px) { .posts-grid { grid-template-columns: 1fr; } nav { gap: 20px; padding: 12px 20px; } }
    .hamburger {
  display: none; flex-direction: column; justify-content: space-between;
  width: 30px; height: 21px; background: transparent;
  border: none; cursor: pointer; padding: 0; z-index: 110;
}
.hamburger span { width:100%; height:3px; background:#fff; border-radius:3px; transition:all 0.3s; }

@media (max-width: 1024px) {
  header { justify-content: flex-end; }
  .hamburger { display: flex; }
  .nav-menu {
    position: absolute; top: -500px; right: 20px; left: 20px;
    flex-direction: column; gap: 25px; padding: 35px 20px;
    border-radius: 20px; opacity: 0; pointer-events: none;
    transition: all 0.4s ease-in-out;
    background: rgba(10,17,39,0.98) !important;
    border: 2px solid rgba(59,130,246,0.8) !important;
  }
  .nav-menu.active { top: 80px; opacity: 1; pointer-events: auto; }
  .nav-menu a { width:100%; text-align:center; padding:10px 0; font-size:1.2rem; color:#fff !important; }
  .hamburger.active span:nth-child(1) { transform: translateY(9px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: translateY(-9px) rotate(-45deg); }
}
  </style>
</head>
<body>
<canvas id="net-bg"></canvas>
  <header>
