---
const { frontmatter } = Astro.props;
---
<!doctype html>
<html lang="hu">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-KD2ZJV6WNY"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-KD2ZJV6WNY');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{frontmatter.title} | netopslab.hu</title>
  <meta name="description" content={frontmatter.description} />
  <meta name="author" content="Nagy Attila" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`https://netopslab.hu/blog/${frontmatter.slug}`} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={frontmatter.title} />
  <meta property="og:description" content={frontmatter.description} />
  <meta property="og:url" content={`https://netopslab.hu/blog/${frontmatter.slug}`} />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛡️</text></svg>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
  <style>
    :root {
      --bg: #050816;
      --card: #0b1224;
      --accent: #3b82f6;
      --text: #e5e7eb;
      --muted: #9ca3af;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: system-ui, sans-serif; }
    body { background: var(--bg); color: var(--text); }

    header {
      position: fixed; top: 0; left: 0; width: 100%;
      padding: 22px 20px;
      display: flex; justify-content: center; align-items: center;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      z-index: 100;
    }
    nav {
      display: flex; justify-content: center; align-items: center;
      gap: 35px; padding: 14px 40px;
      background: rgba(30,41,59,0.55);
      backdrop-filter: blur(15px);
      border-radius: 50px;
      border: 2px solid rgba(59,130,246,0.7);
      box-shadow: 0 10px 40px rgba(0,0,0,0.6);
    }
    nav a {
      text-decoration: none; color: var(--muted);
      font-size: 1rem; font-weight: 600;
      letter-spacing: 0.9px; text-transform: uppercase;
      transition: 0.3s;
    }
    nav a:hover { color: var(--text); }

    .article-wrap {
      max-width: 780px; margin: 0 auto;
      padding: 140px 24px 80px;
    }
    .article-back {
      display: inline-flex; align-items: center; gap: 8px;
      color: #60a5fa; text-decoration: none; font-size: 0.9rem;
      margin-bottom: 32px; transition: 0.2s;
    }
    .article-back:hover { color: #fff; }
    .article-tag {
      display: inline-block; font-size: 0.75rem; font-weight: 700;
      letter-spacing: 1.2px; text-transform: uppercase;
      padding: 4px 14px; border-radius: 20px; margin-bottom: 20px;
      background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.3); color: #93c5fd;
    }
    .article-title {
      font-size: 2.2rem; font-weight: 700; color: #fff;
      line-height: 1.25; margin-bottom: 16px;
    }
    .article-meta {
      color: var(--muted); font-size: 0.88rem; margin-bottom: 40px;
      padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .article-body { line-height: 1.85; color: #cbd5e1; font-size: 1.02rem; }
    .article-body h2 {
      font-size: 1.4rem; font-weight: 700; color: #fff;
      margin: 40px 0 16px;
    }
    .article-body h3 {
      font-size: 1.15rem; font-weight: 700; color: #60a5fa;
      margin: 28px 0 12px;
    }
    .article-body p { margin-bottom: 18px; }
    .article-body ul { padding-left: 20px; margin-bottom: 18px; }
    .article-body li { margin-bottom: 8px; }
    .article-body strong { color: #fff; }
    .article-body a { color: #60a5fa; }

    .cta-box {
      background: var(--card); border: 1px solid rgba(59,130,246,0.3);
      border-radius: 14px; padding: 28px; margin-top: 48px; text-align: center;
    }
    .cta-box h3 { color: #fff; font-size: 1.2rem; margin-bottom: 10px; }
    .cta-box p { color: var(--muted); margin-bottom: 20px; font-size: 0.95rem; }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: #2563eb; color: #fff; text-decoration: none;
      padding: 12px 28px; border-radius: 8px; font-weight: 600;
      transition: all 0.25s;
    }
    .btn-primary:hover { background: #1d4ed8; transform: translateY(-2px); }

    footer {
      padding: 32px 40px; text-align: center; color: var(--muted);
      border-top: 1px solid rgba(255,255,255,0.05); font-size: 0.88rem;
    }

    @media (max-width: 768px) {
      .article-title { font-size: 1.6rem; }
      nav { gap: 20px; padding: 12px 20px; }
      nav a { font-size: 0.85rem; }
    }
  </style>
</head>
<body>
  <header>
 <nav>
  <a href="/">Főoldal</a>
  <a href="/#about">Rólam</a>
  <a href="/#services">Szolgáltatások</a>
  <a href="/blog">Blog</a>
  <a href="/#contact">Kapcsolat</a>
</nav>
  </header>

  <div class="article-wrap">
    <a href="/blog" class="article-back">← Vissza a bloghoz</a>
    <div class="article-tag">{frontmatter.tag}</div>
    <h1 class="article-title">{frontmatter.title}</h1>
    <div class="article-meta">
      Nagy Attila · {frontmatter.date} · {frontmatter.readTime} perc olvasás
    </div>
    <div class="article-body">
      <slot />
    </div>

    <div class="cta-box">
      <h3>Segíthetek a felkészülésben?</h3>
      <p>20+ év tapasztalattal segítek az IT infrastruktúra biztonságossá tételében.</p>
      <a href="/#contact" class="btn-primary">Kapcsolatfelvétel →</a>
    </div>
  </div>

  <footer>© 2026 Nagy Attila — IT Infrastructure & Network Security | Hatvan</footer>
</body>
</html>
